# ─────────────────────────────────────────────────────────
# ASU Reservation System — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# Demo mode — enables /api/v1/admin/* endpoints
DEMO_MODE=true

# ── Optional: Real SMTP email delivery ─────────────────
# Leave all three unset to keep emails simulated (DB-only).
# When all three are set, the server will send real emails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@asu.edu
